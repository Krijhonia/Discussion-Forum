<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DevForum</title>
    <script type="importmap"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootswatch/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="antialiased">
    <header>
        <nav class="navbar navbar-expand-lg custom-nav fixed-top">
            <div class="container py-2">
                <a class="navbar-brand fs-4" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-terminal-split text-primary me-2"></i> DevForum
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarColor01" aria-controls="navbarColor01" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarColor01">
                    <ul class="navbar-nav ms-auto gap-3">
                        <li class="nav-item">
                            <a class="nav-link fs-6" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fs-6" asp-area="" asp-controller="Post" asp-action="Index">Discussions</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-lg-3 gap-2">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item d-flex align-items-center me-3">
                                <span class="text-muted"><i class="bi bi-person-circle me-1"></i> Hello, @User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Profile" asp-action="Index">My Profile</a>
                            </li>
                            <li class="nav-item ms-2">
                                <form  method="post" asp-area="" asp-controller="Account" asp-action="Logout" class="d-inline">
                                    <button type="submit" class="btn btn-outline-secondary btn-sm" style="border-radius: 8px; padding: 0.4rem 1rem;">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-primary btn-sm" asp-controller="Account" asp-action="Login">Sign In</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Register">Sign Up</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container main-container mb-5" style="margin-top: 100px; padding-top: 2rem;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted text-center py-4 mt-auto">
        <div class="container">
            <span class="fw-medium">&copy; 2026 - DevForum</span> - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-light hover-opacity">Privacy Policy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
