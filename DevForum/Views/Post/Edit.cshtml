@model DevForum.Models.ViewModels.EditPostViewModel

@{
    ViewData["Title"] = "Edit Thread";
}

<div class="content-wrapper post-card p-4 p-md-5 mb-5 mt-2 border-0">
    <div class="row mb-4">
        <div class="col-6">
            <h2 class="fw-bold">@ViewData["Title"]</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-action="Index" class="btn btn-outline-primary"><i class="bi bi-arrow-left"></i> Back to Discussions</a>
        </div>
    </div>
    <hr style="border-color: var(--surface-border);">
    <form asp-action="Edit" asp-controller="Post" asp-route-id="@Model.Post.Id" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Post.Id" />
        <input type="hidden" asp-for="Post.FeatureImagePath" />

        <div class="validation-summary">
            <div asp-validation-summary="All" class="text-danger"></div>
        </div>
        <div class="form-group mb-3">
            <label asp-for="Post.Title" class="form-label">Discussion Title</label>
            <input type="text" asp-for="Post.Title" class="form-control" />
            <span asp-validation-for="Post.Title" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Post.CategoryId" class="form-label">Category</label>
            <select asp-for="Post.CategoryId" asp-items="Model.Categories" class="form-select">
                <option value="">Select Category</option>
            </select>
            <span asp-validation-for="Post.CategoryId" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Post.Author" class="form-label">Your Display Name</label>
            <input type="text" asp-for="Post.Author" class="form-control" />
            <span asp-validation-for="Post.Author" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Post.Content" class="form-label">Initial Message</label>
            <textarea asp-for="Post.Content" class="form-control" rows="5"></textarea>
            <span asp-validation-for="Post.Content" class="text-danger"></span>
        </div>

        <div class="form-group mb-4">
            <label asp-for="FeatureImage" class="form-label">Attachment / Header Image (Leave blank to keep existing)</label>
            <input type="file" asp-for="FeatureImage" class="form-control" />
            <span asp-validation-for="FeatureImage" class="text-danger"></span>
            @if (!string.IsNullOrEmpty(Model.Post.FeatureImagePath))
            {
                    <div class="mt-2">
                        <p>Current Image:</p>
                        <img src="@Model.Post.FeatureImagePath" class="img-thumbnail" style="max-height: 200px;" alt="Current Feature Image"/>
                    </div>
            }
        </div>

        <button type="submit" class="btn btn-primary mt-1 px-4">Save Changes</button>
        <a class="btn btn-outline-secondary mt-1 px-4" asp-action="Index" asp-controller="Post">Cancel</a>
    </form>
</div>
@section Scripts{
       <script src="https://cdn.tiny.cloud/1/9j0lqsw6e2wadbewavsjh1dzub7961i0n3h383864l60z8vp/tinymce/8/tinymce.min.js" referrerpolicy="origin" crossorigin="anonymous"></script>
        <script>
             tinymce.init({
            selector: 'textarea',
        });
        </script>
}
