@model DevForum.Models.Post

@{
    ViewData["Title"] = "Delete Thread";
}

<div class="container mt-5">
    <div class="card border-danger border-1" style="background-color: var(--bg-surface);">
        <div class="card-header bg-danger text-white border-0 py-3">
            <h4 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Are you sure you want to delete this thread?</h4>
        </div>
        <div class="card-body p-4 p-md-5">
            <h5 class="card-title fs-3 mb-3" style="color: var(--text-main);">@Model.Title</h5>
            <h6 class="card-title fs-6 mb-4 text-muted"><i class="bi bi-person-circle me-1"></i> @Model.Author | Started on @Model.PublishedDate.ToString("MMM dd, yyyy")</h6>
            <p class="card-text text-muted">Category: @Model.Category?.Name</p>

            @if (!string.IsNullOrEmpty(Model.FeatureImagePath))
            {
                    <img src="@Model.FeatureImagePath" class="img-fluid rounded mb-3" style="max-height: 300px; object-fit: cover;" alt="@Model.Title" />
            }

            <form asp-action="Delete" method="post" class="mt-2">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger px-4">Yes, Delete Thread</button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4 ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>
