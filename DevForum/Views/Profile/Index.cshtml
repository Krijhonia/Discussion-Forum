@using DevForum.Controllers
@model UserProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="row mb-5 align-items-center">
    <div class="col-md-2 text-center text-md-start mb-3 mb-md-0">
        <i class="bi bi-person-circle" style="font-size: 5rem; color: var(--accent-color); text-shadow: 0 0 20px rgba(59, 130, 246, 0.4);"></i>
    </div>
    <div class="col-md-10 text-center text-md-start">
        <h1 class="display-5 fw-bold mb-1">@User.Identity?.Name</h1>
        <div class="text-muted fs-5 d-flex gap-4 justify-content-center justify-content-md-start">
            <span><strong style="color: var(--text-main);">@ViewBag.StartedThreadsCount</strong> Threads Started</span>
            <span><strong style="color: var(--text-main);">@ViewBag.RepliesCount</strong> Total Replies</span>
        </div>
    </div>
</div>

<ul class="nav nav-pills mb-4 gap-2" id="profileTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="btn btn-outline-secondary active px-4" id="threads-tab" data-bs-toggle="tab" data-bs-target="#threads" type="button" role="tab" style="border-radius: 20px;">My Threads</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="btn btn-outline-secondary px-4" id="replies-tab" data-bs-toggle="tab" data-bs-target="#replies" type="button" role="tab" style="border-radius: 20px;">My Replies</button>
    </li>
</ul>

<div class="tab-content" id="profileTabsContent">
    <div class="tab-pane fade show active" id="threads" role="tabpanel" tabindex="0">
        <div class="forum-list mt-3">
            @if (!Model.MyPosts.Any())
            {
                <div class="p-4 text-center text-muted">You haven't started any discussions yet. <a asp-controller="Post" asp-action="Create">Start one now</a>.</div>
            }
            @foreach(var post in Model.MyPosts)
            {
                <div class="forum-item align-items-center">
                    <div class="flex-grow-1">
                        <a asp-action="Detail" asp-controller="Post" asp-route-id="@post.Id" class="forum-title d-block mb-1">@post.Title</a>
                        <div class="forum-meta">
                            <span class="badge-category me-2">@(post.Category?.Name ?? "Tech")</span>
                            <span>Started on @post.PublishedDate.ToString("MMM dd, yyyy")</span>
                        </div>
                    </div>
                    <div class="ms-3 text-end d-none d-md-block text-muted">
                        <div class="fs-6"><i class="bi bi-reply-fill ms-3"></i> @(post.Comments?.Count ?? 0)</div>
                        <small>replies</small>
                    </div>
                </div>
            }
        </div>
    </div>
    
    <div class="tab-pane fade" id="replies" role="tabpanel" tabindex="0">
        <div class="forum-list mt-3">
            @if (!Model.MyComments.Any())
            {
                <div class="p-4 text-center text-muted">You haven't replied to any threads yet.</div>
            }
            @foreach(var comment in Model.MyComments)
            {
                <div class="forum-item align-items-center">
                    <div class="flex-grow-1">
                        <div class="mb-2 text-muted fs-6">
                            Replied in: <a asp-action="Detail" asp-controller="Post" asp-route-id="@comment.Post.Id" style="color: var(--accent-color);">@comment.Post.Title</a>
                        </div>
                        <div style="color: #e5e5e5; font-size: 1rem; font-weight: 300; border-left: 3px solid rgba(59, 130, 246, 0.5); padding-left: 15px;">
                            "@comment.Content"
                        </div>
                        <div class="forum-meta mt-2">
                            <span>Posted on @comment.CommentDate.ToString("MMM dd, yyyy HH:mm")</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
