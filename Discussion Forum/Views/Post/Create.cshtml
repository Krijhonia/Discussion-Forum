@model PostViewModel

@{
    ViewData["Title"] = "Start a Discussion";
}

<div class="content-wrapper post-card p-4 p-md-5 mb-5 mt-2 border-0">
    <div class="row mb-4">
        <div class="col-6">
            <h2 class="fw-bold">@ViewData["Title"]</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-action="Index" class="btn btn-outline-primary"><i class="bi bi-arrow-left"></i> Back to
                Discussions</a>
        </div>
    </div>
    <hr style="border-color: var(--surface-border);">
    <form asp-action="Create" asp-controller="Post" method="post" enctype="multipart/form-data">
        <div class="validation-summary">
            <div asp-validation-summary="All" class="text-danger"></div>
        </div>
        <div class="form-group mb-3">
            <label for="" asp-for="Post.Title" class="form-label">Discussion Title</label>
            <input type="text" asp-for="Post.Title" class="form-control" />
            <span asp-validation-for="Post.Title" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label for=" " asp-for="Post.CategoryId" class="form-label">Category</label>
            <select asp-for="Post.CategoryId" asp-items="Model.Categories" class="form-select">
                <option value="">Select Category</option>
            </select>
            <span asp-validation-for="Post.CategoryId" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label for="" asp-for="Post.Author" class="form-label">Your Display Name</label>
            <input type="text" asp-for="Post.Author" class="form-control" />
            <span asp-validation-for="Post.Author" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label for="" asp-for="Post.Content" class="form-label">Initial Message</label>
            <input type="hidden" asp-for="Post.Content" id="Post_Content" />
            <div class="tiptap-wrapper">
                <div class="tiptap-toolbar" id="toolbar-create">
                    <div class="tiptap-toolbar-group">
                        <button type="button" class="tiptap-btn" data-action="undo" title="Undo"><i
                                class="bi bi-arrow-counterclockwise"></i></button>
                        <button type="button" class="tiptap-btn" data-action="redo" title="Redo"><i
                                class="bi bi-arrow-clockwise"></i></button>
                    </div>
                    <div class="tiptap-toolbar-divider"></div>
                    <div class="tiptap-toolbar-group">
                        <select class="tiptap-select" data-action="heading" title="Text style">
                            <option value="0">Paragraph</option>
                            <option value="1">Heading 1</option>
                            <option value="2">Heading 2</option>
                            <option value="3">Heading 3</option>
                        </select>
                    </div>
                    <div class="tiptap-toolbar-divider"></div>
                    <div class="tiptap-toolbar-group">
                        <button type="button" class="tiptap-btn" data-action="bold" title="Bold"><i
                                class="bi bi-type-bold"></i></button>
                        <button type="button" class="tiptap-btn" data-action="italic" title="Italic"><i
                                class="bi bi-type-italic"></i></button>
                        <button type="button" class="tiptap-btn" data-action="underline" title="Underline"><i
                                class="bi bi-type-underline"></i></button>
                        <button type="button" class="tiptap-btn" data-action="strike" title="Strikethrough"><i
                                class="bi bi-type-strikethrough"></i></button>
                    </div>
                    <div class="tiptap-toolbar-divider"></div>
                    <div class="tiptap-toolbar-group">
                        <button type="button" class="tiptap-btn" data-action="alignLeft" title="Align left"><i
                                class="bi bi-text-left"></i></button>
                        <button type="button" class="tiptap-btn" data-action="alignCenter" title="Align center"><i
                                class="bi bi-text-center"></i></button>
                        <button type="button" class="tiptap-btn" data-action="alignRight" title="Align right"><i
                                class="bi bi-text-right"></i></button>
                    </div>
                    <div class="tiptap-toolbar-divider"></div>
                    <div class="tiptap-toolbar-group">
                        <button type="button" class="tiptap-btn" data-action="bulletList" title="Bullet list"><i
                                class="bi bi-list-ul"></i></button>
                        <button type="button" class="tiptap-btn" data-action="orderedList" title="Ordered list"><i
                                class="bi bi-list-ol"></i></button>
                    </div>
                    <div class="tiptap-toolbar-divider"></div>
                    <div class="tiptap-toolbar-group">
                        <button type="button" class="tiptap-btn" data-action="codeBlock" title="Code block"><i
                                class="bi bi-code-square"></i></button>
                        <button type="button" class="tiptap-btn" data-action="blockquote" title="Blockquote"><i
                                class="bi bi-blockquote-left"></i></button>
                        <button type="button" class="tiptap-btn" data-action="link" title="Insert link"><i
                                class="bi bi-link-45deg"></i></button>
                    </div>
                    <div class="tiptap-toolbar-divider"></div>
                    <div class="tiptap-toolbar-group">
                        <button type="button" class="tiptap-btn" data-action="clearFormat" title="Clear formatting"><i
                                class="bi bi-eraser"></i></button>
                    </div>
                </div>
                <div class="tiptap-editor" id="editor-create"></div>
            </div>
            <span asp-validation-for="Post.Content" class="text-danger"></span>
        </div>
        <div class="form-group mb-4">
            <label for="" asp-for="FeatureImage" class="form-label">Attachment (Optional)</label>
            <input type="file" asp-for="FeatureImage" class="form-control"
                accept=".jpg,.jpeg,.png,.gif,.pdf,.doc,.docx,.ppt,.pptx" />
            <small class="text-muted d-block mt-1">Accepted formats: Images (.jpg, .png, .gif), PDF, Word (.doc, .docx),
                PowerPoint (.ppt, .pptx)</small>
            <span asp-validation-for="FeatureImage" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary mt-1 px-4">Post Discussion</button>
        <a class="btn btn-outline-secondary mt-1 px-4" asp-action="Index" asp-controller="Post">Cancel</a>
    </form>
</div>
@section Scripts{
    <script src="~/js/tiptap-editor.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            initTiptapEditor('editor-create', 'toolbar-create', 'Post_Content');
        });
    </script>
}