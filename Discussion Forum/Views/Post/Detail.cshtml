@using Microsoft.EntityFrameworkCore.Metadata.Internal
@model Post
@{
    ViewData["Title"] = Model.Title;
}

<div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8">

        <div class="mb-4 mt-4">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back to
                Discussions</a>
        </div>

        <div class="post-header">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <span class="badge-category mb-3 d-inline-block">@Model.Category?.Name</span>
                    <h1 class="mb-2">@Model.Title</h1>
                    <div class="text-muted fs-6 d-flex align-items-center gap-2">
                        <i class="bi bi-person-circle post-author-icon"></i> <strong>@Model.Author</strong>
                        <span>•</span>
                        <span>@Model.PublishedDate.ToString("MMM dd, yyyy")</span>
                    </div>
                </div>
                <div>
                    <a asp-action="Edit" asp-controller="Post" asp-route-id="@Model.Id"
                        class="btn btn-outline-secondary btn-sm me-2"><i class="bi bi-pencil-square"></i> Edit</a>
                    <a asp-action="Delete" asp-controller="Post" asp-route-id="@Model.Id"
                        class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i> Delete</a>
                </div>
            </div>
        </div>

        <div class="post-content-box mb-5 mt-4">
            @if (!string.IsNullOrEmpty(Model.FeatureImagePath))
            {

                var extension = System.IO.Path.GetExtension(Model.FeatureImagePath).ToLower();
                    <div class="mb-4 text-center">
                    @if (extension == ".pdf")

                    {
                                <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
                                    <i class="bi bi-file-earmark-pdf" style="font-size: 1.2rem; color: #dc3545;"></i>
                                    <a href="@Model.FeatureImagePath" target="_blank" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-box-arrow-up-right me-1"></i>Open PDF in New Tab
                                    </a>
                                    <a href="@Model.FeatureImagePath" download class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-download me-1"></i>Download
                                    </a>
                                </div>
                                <iframe src="@Model.FeatureImagePath"
                                    style="width: 100%; height: 600px; border: 1px solid var(--border-subtle); border-radius: 8px;"
                                    title="PDF Attachment"></iframe>
                    }

                    else if (extension == ".doc" || extension == ".docx")

                    {
                                <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
                                    <i class="bi bi-file-earmark-word" style="font-size: 1.2rem; color: #2b579a;"></i>
                                    <span class="text-muted">Word Document</span>
                                    <a href="@Model.FeatureImagePath" download class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-download me-1"></i>Download
                                    </a>
                                </div>
                                <div id="docx-preview-container"
                                    data-file-url="@Model.FeatureImagePath"
                                    style="width: 100%; min-height: 500px; border: 1px solid var(--border-subtle); border-radius: 8px; background: #fff; overflow: auto; text-align: left;">
                                    <div class="text-center p-4 text-muted">
                                        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                                        Loading document preview...
                                    </div>
                                </div>
                    }

                    else if (extension == ".pptx")

                    {
                                <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
                                    <i class="bi bi-file-earmark-ppt" style="font-size: 1.2rem; color: #d24726;"></i>
                                    <span class="text-muted">PowerPoint Presentation</span>
                                    <a href="@Model.FeatureImagePath" download class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-download me-1"></i>Download
                                    </a>
                                </div>
                                <div id="pptx-preview-container"
                                    data-file-url="@Model.FeatureImagePath"
                                    style="width: 100%; min-height: 500px; border: 1px solid var(--border-subtle); border-radius: 8px; background: #fff; overflow: auto;">
                                    <div class="text-center p-4 text-muted">
                                        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                                        Loading presentation preview...
                                    </div>
                                </div>
                    }

                    else if (extension == ".ppt")

                    {
                                <div class="p-4 rounded"
                                    style="border: 1px dashed var(--border-subtle); background: var(--bg-surface);">
                                    <i class="bi bi-file-earmark-ppt" style="font-size: 2rem; color: #d24726;"></i>
                                    <p class="mt-2 mb-2 text-muted">PowerPoint Presentation (.ppt) — Preview not available for legacy format</p>
                                    <a href="@Model.FeatureImagePath" download class="btn btn-primary btn-sm">
                                        <i class="bi bi-download me-1"></i>Download Presentation
                                    </a>
                                </div>
                    }

                    else

                    {
                                <img src="@Model.FeatureImagePath" alt="Attachment" class="img-fluid rounded"
                                    style="width: 100%; max-height: 800px; object-fit: contain; border: 1px solid var(--border-subtle);" />
                    }
                    </div>
            }

            <div class="fs-5 lh-lg post-content">
                @Html.Raw(Model.Content)
            </div>
        </div>

        <div id="commentSection" class="mt-5">
            <h3 class="mb-4">Comments (@Model.Comments.Count)</h3>

            @if (!Model.Comments.Any())
            {
                    <div class="comment-box text-center p-4 text-muted mb-4" id="noRepliesDiv">
                        No replies yet. Be the first to share your thoughts!
                    </div>
            }
            else
            {

                foreach (var comment in Model.Comments.Where(c => c.ParentCommentId == null).OrderBy(c => c.CommentDate))

                {
                    @await Html.PartialAsync("_CommentPartial", comment)
                }
            }
        </div>

        <div class="comment-box mt-5 p-4">
            <h4 class="mb-4">Post a Reply</h4>
            <form id="commentForm">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="Username" class="form-label">Display Name</label>
                        <input type="text" id="Username" name="Username" class="form-control" autocomplete="off"
                            value="@(User.Identity.IsAuthenticated ? User.Identity.Name : "")"
                        @(User.Identity.IsAuthenticated ? "readonly" : "")>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="Content" class="form-label">Message</label>
                    <textarea name="Content" id="Content" rows="4" required class="form-control"
                        placeholder="Write your reply..."></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Submit Reply</button>
            </form>
        </div>

    </div>
</div>

@section Scripts{
        <script>
            $(document).ready(function () {
                function submitComment(parentCommentId, content, callback) {
                    var userName = $("#Username").val();
                    if (!userName || !content) return;

                    var postId = @Model.Id;
                    $.ajax({
                        url: '@Url.Action("AddComment","Post")',
                        type: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify({
                            Username: userName,
                            Content: content,
                            PostId: postId,
                            ParentCommentId: parentCommentId
                        }),
                        success: function (response) {
                            if (callback) callback(response);
                            $('#noRepliesDiv').remove();
                            hljs.highlightAll();
                        }
                    });
                }

                function buildCommentHtml(response, parentUsername) {
                    var replyingTo = parentUsername
                        ? `replied to <strong style="color: var(--text-main);">${parentUsername}</strong>`
                        : 'replied';
                    return `
                        <div class="comment-item mb-3" data-comment-id="${response.commentId}">
                            <div class="comment-box p-3">
                                <div class="comment-meta text-muted border-bottom pb-2 mb-3" style="border-color: var(--border-subtle) !important;">
                                    <span><strong style="color: var(--text-main);">${response.username}</strong> ${replyingTo}</span>
                                    <span>${response.commentDate}</span>
                                </div>
                                <div class="comment-body fs-6">${response.comment}</div>
                                <div class="comment-actions mt-3">
                                    <button type="button" class="btn btn-link btn-sm reply-button" data-comment-id="${response.commentId}" data-comment-user="${response.username}"><i class="bi bi-reply-fill"></i> Reply</button>
                                </div>
                            </div>
                            <div class="nested-reply-area d-none mt-3">
                                <form class="nestedReplyForm" data-parent-id="${response.commentId}">
                                    <div class="mb-3">
                                        <label class="form-label">Replying to ${response.username}</label>
                                        <textarea class="form-control reply-content" rows="3" placeholder="Reply to ${response.username}..."></textarea>
                                    </div>
                                    <button type="submit" class="btn btn-primary btn-sm">Submit Reply</button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm cancel-reply">Cancel</button>
                                </form>
                            </div>
                        </div>`;
                }

                // Top-level comment submission
                $("#commentForm").on('submit', function (event) {
                    event.preventDefault();
                    var content = $("#Content").val();
                    if (!content) return;

                    submitComment(null, content, function (response) {
                        $('#commentForm')[0].reset();
        @if (User.Identity.IsAuthenticated)

        {
            @:$("#Username").val('@User.Identity.Name');
        }
                        var html = buildCommentHtml(response, null);
                        $('#commentSection').append(html);
                    });
                });

                // Show reply form (only the immediate one, not children)
                $(document).on('click', '.reply-button', function () {
                    $('.nested-reply-area').addClass('d-none');
                    var commentItem = $(this).closest('.comment-item');
                    commentItem.children('.nested-reply-area').removeClass('d-none');
                    commentItem.children('.nested-reply-area').find('.reply-content').focus();
                });

                $(document).on('click', '.cancel-reply', function () {
                    $(this).closest('.nested-reply-area').addClass('d-none');
                });

                // Nested reply submission — creates a new nested comment under the parent
                $(document).on('submit', '.nestedReplyForm', function (event) {
                    event.preventDefault();
                    var form = $(this);
                    var parentCommentId = form.data('parent-id');
                    var parentUser = form.closest('.comment-item').find('.reply-button').first().data('comment-user');
                    var content = form.find('.reply-content').val();
                    if (!content) return;

                    submitComment(parentCommentId, content, function (response) {
                        var html = buildCommentHtml(response, parentUser);
                        var commentItem = form.closest('.comment-item');
                        var repliesArea = commentItem.children('.comment-replies');
                        if (!repliesArea.length) {
                            repliesArea = $('<div class="comment-replies mt-3"></div>');
                            commentItem.append(repliesArea);
                        }
                        repliesArea.append(html);
                        form.closest('.nested-reply-area').addClass('d-none');
                        form.find('.reply-content').val('');
                    });
                });
            });
        </script>

        @* Word Document Preview using mammoth.js (supports .doc and .docx) + docx-preview *@
        <script src="https://cdn.jsdelivr.net/npm/mammoth@1.8.0/mammoth.browser.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/docx-preview@0.3.3/dist/docx-preview.min.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var docxContainer = document.getElementById('docx-preview-container');
                if (docxContainer) {
                    var fileUrl = docxContainer.getAttribute('data-file-url');

                    fetch(fileUrl)
                        .then(function (response) {
                            if (!response.ok) throw new Error('Failed to load document');
                            return response.arrayBuffer();
                        })
                        .then(function (arrayBuffer) {
                            var blob = new Blob([arrayBuffer]);

                            if (typeof docx !== 'undefined' && docx.renderAsync) {
                                docx.renderAsync(blob, docxContainer, null, {
                                    className: 'docx-preview-content',
                                    inWrapper: true,
                                    ignoreWidth: false,
                                    ignoreHeight: false,
                                    ignoreFonts: false,
                                    breakPages: true,
                                    ignoreLastRenderedPageBreak: true
                                }).catch(function () {
                                    renderWithMammoth(arrayBuffer, docxContainer);
                                });
                            } else {
                                renderWithMammoth(arrayBuffer, docxContainer);
                            }
                        })
                        .catch(function (err) {
                            docxContainer.innerHTML = '<div class="p-4 text-center text-muted">' +
                                '<i class="bi bi-exclamation-triangle" style="font-size: 2rem; color: #fbbf24;"></i>' +
                                '<p class="mt-2">Could not load document. Please download instead.</p></div>';
                        });
                }

                function renderWithMammoth(arrayBuffer, container) {
                    mammoth.convertToHtml({ arrayBuffer: arrayBuffer })
                        .then(function (result) {
                            container.innerHTML =
                                '<div style="padding: 2rem; font-family: Inter, sans-serif; line-height: 1.8; color: #1f2937;">' +
                                result.value +
                                '</div>';
                        })
                        .catch(function (err) {
                            container.innerHTML = '<div class="p-4 text-center text-muted">' +
                                '<i class="bi bi-exclamation-triangle" style="font-size: 2rem; color: #fbbf24;"></i>' +
                                '<p class="mt-2">Could not render document preview. Please download instead.</p></div>';
                        });
                }

                var pptxContainer = document.getElementById('pptx-preview-container');
                if (pptxContainer) {
                    pptxContainer.innerHTML =
                        '<div class="p-4 text-center">' +
                            '<i class="bi bi-file-earmark-ppt" style="font-size: 3rem; color: #d24726;"></i>' +
                            '<p class="mt-3 mb-2 text-muted">PowerPoint preview is available when deployed to a public server.</p>' +
                            '<p class="text-muted small">For now, please download the file to view it.</p>' +
                        '</div>';
                }
            });
        </script>
}