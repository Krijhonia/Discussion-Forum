@using Microsoft.EntityFrameworkCore.Metadata.Internal
@model Post
@{
    ViewData["Title"] = Model.Title;
}

<div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8">

        <div class="mb-4 mt-4">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back to Discussions</a>
        </div>

        <div class="post-header">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <span class="badge-category mb-3 d-inline-block">@Model.Category?.Name</span>
                    <h1 class="mb-2">@Model.Title</h1>
                    <div class="text-muted fs-6 d-flex align-items-center gap-2">
                        <i class="bi bi-person-circle post-author-icon"></i> <strong>@Model.Author</strong>
                        <span>•</span>
                        <span>@Model.PublishedDate.ToString("MMM dd, yyyy")</span>
                    </div>
                </div>
                <div>
                    <a asp-action="Edit" asp-controller="Post" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm me-2"><i class="bi bi-pencil-square"></i> Edit</a>
                    <a asp-action="Delete" asp-controller="Post" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i> Delete</a>
                </div>
            </div>
        </div>

        <div class="post-content-box mb-5 mt-4">
            @if (!string.IsNullOrEmpty(Model.FeatureImagePath))
            {
                <div class="mb-4 text-center">
                    <img src="@Model.FeatureImagePath" alt="Attachment" class="img-fluid rounded" style="max-height: 500px; border: 1px solid var(--border-subtle);" />
                </div>
            }
            
            <div class="fs-5 lh-lg post-content">
                @Html.Raw(Model.Content)
            </div>
        </div>

        <div id="commentSection" class="mt-5">
            <h3 class="mb-4">Comments (@Model.Comments.Count)</h3>
            
            @if (!Model.Comments.Any())
            {
                <div class="comment-box text-center p-4 text-muted mb-4" id="noRepliesDiv">
                    No replies yet. Be the first to share your thoughts!
                </div>
            }
            else
            {
                @foreach (var comment in Model.Comments.Where(c => c.ParentCommentId == null).OrderBy(c => c.CommentDate))
                {
                    <div class="comment-item mb-4" data-comment-id="@comment.Id">
                        <div class="comment-box p-3"> <div class="comment-meta text-muted border-bottom pb-2 mb-3" style="border-color: var(--border-subtle) !important;">
                                <span><strong style="color: var(--text-main);">@comment.Username</strong> replied</span>
                                <span>@comment.CommentDate.ToString("MMM dd, yyyy HH:mm")</span>
                            </div>
                            
                            <div class="comment-body fs-6">@Html.Raw(comment.Content)</div>
                            
                            <div class="comment-actions mt-3">
                                <button type="button" class="btn btn-link btn-sm reply-button" data-comment-id="@comment.Id" data-comment-user="@comment.Username"><i class="bi bi-reply-fill"></i> Reply</button>
                            </div>
                        </div>

                        @if (comment.Replies.Any())
                        {
                            <div class="comment-replies mt-4">
                                @foreach (var reply in comment.Replies.OrderBy(r => r.CommentDate))
                                {
                                    <div class="reply-box p-3"> <div class="comment-meta text-muted border-bottom pb-2 mb-3" style="border-color: var(--border-subtle) !important;">
                                            <span><strong style="color: var(--text-main);">@reply.Username</strong> replied to @comment.Username</span>
                                            <span>@reply.CommentDate.ToString("MMM dd, yyyy HH:mm")</span>
                                        </div>

                                        <div class="comment-body fs-6">@Html.Raw(reply.Content)</div>
                                    </div>
                                }
                            </div>
                        }

                        <div class="nested-reply-area d-none mt-3">
                            <form class="nestedReplyForm" data-parent-id="@comment.Id">
                                <div class="mb-3">
                                    <label class="form-label">Replying to @comment.Username</label>
                                    <textarea class="form-control reply-content" rows="3" placeholder="Reply to @comment.Username..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary btn-sm">Submit Reply</button>
                                <button type="button" class="btn btn-outline-secondary btn-sm cancel-reply">Cancel</button>
                            </form>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="comment-box mt-5 p-4">
            <h4 class="mb-4">Post a Reply</h4>
            <form id="commentForm">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="Username" class="form-label">Display Name</label>
                        <input type="text" id="Username" name="Username" class="form-control" autocomplete="off" value="@(User.Identity.IsAuthenticated ? User.Identity.Name : "")" @(User.Identity.IsAuthenticated ? "readonly" : "")>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="Content" class="form-label">Message</label>
                    <small class="text-muted d-block mb-2"><i class="bi bi-info-circle"></i> Tip: Add code with syntax highlighting using &lt;code class="language-csharp"&gt;your code&lt;/code&gt; (supports: csharp, javascript, python, html, sql, etc.)</small>
                    <textarea name="Content" id="Content" rows="4" required class="form-control" placeholder="Write your reply..."></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Submit Reply</button>
            </form>
        </div>

    </div> </div> @section Scripts{
    <script>
        $(document).ready(function () {
            function submitComment(parentCommentId, content, callback) {
                var userName = $("#Username").val();
                if (!userName || !content) return;

                var postId = @Model.Id;
                $.ajax({
                    url: '@Url.Action("AddComment","Post")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        Username: userName,
                        Content: content,
                        PostId: postId,
                        ParentCommentId: parentCommentId
                    }),
                    success: function (response) {
                        if (callback) callback(response);
                        $('#noRepliesDiv').remove();
                        hljs.highlightAll();
                    }
                });
            }

            $("#commentForm").on('submit', function (event) {
                event.preventDefault();
                var content = $("#Content").val();
                if (!content) return;

                submitComment(null, content, function(response) {
                    $('#commentForm')[0].reset();
                    @if(User.Identity.IsAuthenticated)
                    {
                        @: $("#Username").val('@User.Identity.Name');
                    }
                    var newCommentHTML = `
                    <div class="comment-item mb-4" data-comment-id="${response.commentId}">
                        <div class="comment-box p-3">
                            <div class="comment-meta text-muted border-bottom pb-2 mb-3" style="border-color: var(--border-subtle) !important;">
                                <span><strong style="color: var(--text-main);">${response.username}</strong> replied Just Now</span>
                                <span>${response.commentDate}</span>
                            </div>
                            <div class="comment-body fs-6">${response.comment}</div>
                            <div class="comment-actions mt-3">
                                <button type="button" class="btn btn-link btn-sm reply-button" data-comment-id="${response.commentId}" data-comment-user="${response.username}"><i class="bi bi-reply-fill"></i> Reply</button>
                            </div>
                        </div>
                        <div class="nested-reply-area d-none mt-3">
                            <form class="nestedReplyForm" data-parent-id="${response.commentId}">
                                <div class="mb-3">
                                    <label class="form-label">Replying to ${response.username}</label>
                                    <textarea class="form-control reply-content" rows="3" placeholder="Reply to ${response.username}..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary btn-sm">Submit Reply</button>
                                <button type="button" class="btn btn-outline-secondary btn-sm cancel-reply">Cancel</button>
                            </form>
                        </div>
                    </div>
                    `;
                    $('#commentSection').append(newCommentHTML);
                });
            });

            $(document).on('click', '.reply-button', function () {
                $('.nested-reply-area').addClass('d-none');
                var commentItem = $(this).closest('.comment-item');
                commentItem.find('.nested-reply-area').removeClass('d-none');
                commentItem.find('.reply-content').focus();
            });

            $(document).on('click', '.cancel-reply', function () {
                $(this).closest('.nested-reply-area').addClass('d-none');
            });

            $(document).on('submit', '.nestedReplyForm', function (event) {
                event.preventDefault();
                var form = $(this);
                var parentCommentId = form.data('parent-id');
                var content = form.find('.reply-content').val();
                if (!content) return;

                submitComment(parentCommentId, content, function(response) {
                    var replyHtml = `
                    <div class="reply-box p-3">
                        <div class="comment-meta text-muted border-bottom pb-2 mb-3" style="border-color: var(--border-subtle) !important;">
                            <span><strong style="color: var(--text-main);">${response.username}</strong> replied</span>
                            <span>${response.commentDate}</span>
                        </div>
                        <div class="comment-body fs-6">${response.comment}</div>
                    </div>
                    `;
                    var replyArea = form.closest('.comment-item').find('.comment-replies');
                    if (!replyArea.length) {
                        replyArea = $('<div class="comment-replies mt-4"></div>');
                        form.before(replyArea);
                    }
                    replyArea.append(replyHtml);
                    form.addClass('d-none');
                    form.find('.reply-content').val('');
                });
            });
        });
    </script>
}